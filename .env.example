# Copy to .env for local dev. Never commit .env.

# --- Required in prod -------------------------------------------------

# Postgres connection string. On Railway, bind to ${{Postgres.DATABASE_URL}}.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/hive

# HMAC secret for player session tokens. Generate with:
#   openssl rand -hex 32
HIVE_AUTH_SECRET=change-me-with-openssl-rand-hex-32

# Admin panel password. Single-user; leave unset to disable admin.
ADMIN_PASSWORD=change-me

# --- Optional ---------------------------------------------------------

# HTTP port (the platform will inject one on Railway / Fly).
# PORT=8787

# Bind address.
# HOST=0.0.0.0

# Fastify log level: 'info' | 'debug' | 'warn' | 'error' | 'fatal' | 'silent'
# LOG_LEVEL=info

# Public WebSocket URL for the Colyseus arena. Leave unset in single-
# service deploys (client falls back to <same origin>/arena).
# ARENA_URL=wss://your-domain/arena

# --- Observability (optional, defaults: disabled) --------------------

# Client-side Sentry DSN (stamped into the built bundle).
# SENTRY_DSN_CLIENT=

# Server-side Sentry DSN.
# SENTRY_DSN_SERVER=

# PostHog project key (client-side analytics).
# POSTHOG_KEY=
# POSTHOG_HOST=https://app.posthog.com

# --- Beta gate (optional) --------------------------------------------

# When set to 'true', the client requires ?cohort=beta in the URL
# (or localStorage['hive.cohort']='beta') to load the game. Lets you
# point traffic at a URL before general launch.
# PUBLIC_BETA_GATE=false
